# Client-side (Vite) — required for browser Supabase client
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# Server-side (SSR) — required for server rendering
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-anon-key

# Required for admin seed script and server-side user management
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Development admin bootstrap (scripts/seed-admin.mjs only — never commit real passwords)
ADMIN_EMAIL=admin@amtmti.org
ADMIN_PASSWORD=change-me-in-production
ADMIN_DISPLAY_NAME=AMTMTI Administrator
