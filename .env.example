# Client-side (Vite) — required for browser Supabase client
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Server-side (SSR) — required for server rendering and server-only auth middleware
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Required for npm run seed:admin (Dashboard → Settings → API → Secret key)
SUPABASE_SERVICE_ROLE_KEY=your-sb-secret-or-service-role-key

# Alternative for npm run setup:admin (Dashboard → Settings → Database → password)
SUPABASE_DB_PASSWORD=your-database-password

# Development admin bootstrap (scripts/seed-admin.mjs only — never commit real passwords)
ADMIN_EMAIL=admin@amtmti.org
ADMIN_PASSWORD=change-me-in-production
ADMIN_DISPLAY_NAME=AMTMTI Administrator
